{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
  "packages": [
    "zig@0.15.2",
    "just@latest"
  ],
  "shell": {
    "init_hook": [
      "echo 'Carl development environment ready. Zig 0.15.2 available.'"
    ],
    "scripts": {
      "build": [
        "just build"
      ],
      "test": [
        "just test"
      ],
      "run": [
        "just run -- \"$@\""
      ],
      "sync-augment": [
        "just sync-augment"
      ],
      "install": [
        "OPTIMIZE=ReleaseSafe just install"
      ]
    }
  }
}
